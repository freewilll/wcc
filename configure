#!/bin/sh

set -e

# Show the help
help() {
    cat <<END
Usage: ./configure [options]

Flags:
--prefix=PATH Install prefix, default: /usr
--as=PATH     Use assembler binary (detected: $DEFAULT_AS_COMMAND)
--ld=PATH     Use linker binary    (detected: $DEFAULT_LD_COMMAND)
-h, --help    Print this help text.
END
    exit 0
}

# Configure:
# - as binary
# - ld binary
#
# The results are written to config.h

PREFIX=/usr # Default prefix

# Search for the was binary first, then as
DEFAULT_AS_COMMAND="${AS:-$(command -v was || command -v as || true)}"
DEFAULT_LD_COMMAND="${LD:-$(command -v wld || command -v ld || true)}"

if [ -z "${DEFAULT_AS_COMMAND:-}" ]; then
    echo "Unable to locate an assembler. Install one, or use --as to specify the path to one."
    exit 1
fi

if [ -z "${DEFAULT_LD_COMMAND:-}" ]; then
    echo "Unable to locate a linker. Install one, or use --ld to specify the path to one."
    exit 1
fi

echo Using assembler $DEFAULT_AS_COMMAND
echo Using linker $DEFAULT_LD_COMMAND


# Parse args
for arg in "$@"; do
    case $arg in
    --prefix=*)   PREFIX="${arg#*=}" ;;
    --as=*)       DEFAULT_AS_COMMAND="${arg#*=}" ;;
    --ld=*)       DEFAULT_LD_COMMAND="${arg#*=}" ;;
    -h|--help) help ;;
    *) echo "Unknown arg: $arg" >&2; exit 1 ;;
    esac
    shift || true
done

FILE_crt1=$(gcc -print-file-name=crt1.o)
FILE_crti=$(gcc -print-file-name=crti.o)
FILE_crtn=$(gcc -print-file-name=crtn.o)
FILE_crtbegin=$(gcc -print-file-name=crtbegin.o)
FILE_crtend=$(gcc -print-file-name=crtend.o)
GCC_LIBRARY_PATH=$(dirname "$(gcc -print-libgcc-file-name)")

echo Using GCC library path $GCC_LIBRARY_PATH

# Libc configs are chosen at runtime via wcc --libc=glibc|musl.
GLIBC_DYNAMIC_LINKER=/lib64/ld-linux-x86-64.so.2
GLIBC_LIBC_LIBRARY_PATH=/usr/lib
GLIBC_STARTFILES="$FILE_crt1 $FILE_crti $FILE_crtbegin"
GLIBC_ENDFILES="$FILE_crtend $FILE_crtn"
GLIBC_INCLUDE_PATHS='"/usr/local/include", "/usr/include/x86_64-linux-gnu", "/usr/include"'

echo Using glibc library path $GLIBC_LIBC_LIBRARY_PATH

# Determine musl paths
MUSL_DYNAMIC_LINKER=/lib/ld-musl-x86_64.so.1

if [ -d "/usr/lib/x86_64-linux-musl" ]; then
    MUSL_LIBC_LIBRARY_PATH=/usr/lib/x86_64-linux-musl
elif [ -d "/usr/x86_64-linux-musl/lib64" ]; then
    MUSL_LIBC_LIBRARY_PATH=/usr/x86_64-linux-musl/lib64
else
    # Not sure if this is sane default, but configure should not fail if musl isn't found
    MUSL_LIBC_LIBRARY_PATH=/usr/lib
fi

if [ -d "/usr/include/x86_64-linux-musl" ]; then
    MUSL_INCLUDE_PATHS='"/usr/include/x86_64-linux-musl"'
elif [ -d "/usr/x86_64-linux-musl/include" ]; then
    MUSL_INCLUDE_PATHS='"/usr/x86_64-linux-musl/include"'
else
    # Not sure if this is sane default, but configure should not fail if musl isn't found
    MUSL_INCLUDE_PATHS='"/usr/include"'
fi

MUSL_STARTFILES="$MUSL_LIBC_LIBRARY_PATH/Scrt1.o $MUSL_LIBC_LIBRARY_PATH/crti.o $FILE_crtbegin"
MUSL_ENDFILES="$FILE_crtend $MUSL_LIBC_LIBRARY_PATH/crtn.o"

echo Using musl library path $MUSL_LIBC_LIBRARY_PATH
echo Using musl include path $MUSL_INCLUDE_PATHS

# Write out config.h
CONFIG_H_PATH=config.h

cat > $CONFIG_H_PATH <<END
// This file is auto generated. Do not edit.

#define DEFAULT_AS_COMMAND "$DEFAULT_AS_COMMAND"
#define DEFAULT_LD_COMMAND "$DEFAULT_LD_COMMAND"
#define GCC_LIBRARY_PATH "$GCC_LIBRARY_PATH"
#define GLIBC_DYNAMIC_LINKER "$GLIBC_DYNAMIC_LINKER"
#define GLIBC_LIBC_LIBRARY_PATH "$GLIBC_LIBC_LIBRARY_PATH"
#define GLIBC_STARTFILES "$GLIBC_STARTFILES"
#define GLIBC_ENDFILES "$GLIBC_ENDFILES"
#define GLIBC_INCLUDE_PATHS $GLIBC_INCLUDE_PATHS
#define MUSL_DYNAMIC_LINKER "$MUSL_DYNAMIC_LINKER"
#define MUSL_LIBC_LIBRARY_PATH "$MUSL_LIBC_LIBRARY_PATH"
#define MUSL_STARTFILES "$MUSL_STARTFILES"
#define MUSL_ENDFILES "$MUSL_ENDFILES"
#define MUSL_INCLUDE_PATHS $MUSL_INCLUDE_PATHS
END

# Write out config.mk
CONFIG_MK_PATH=config.mk
cat > $CONFIG_MK_PATH <<END
PREFIX := $PREFIX
END

SRC_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
BUILD_DIR=$(pwd)

if [ "$SRC_DIR" != "$BUILD_DIR" ]
then
    mkdir -p tools
    mkdir -p tests/unit
    mkdir -p tests/integration
    mkdir -p tests/cpp
    mkdir -p tests/e2e

    cp "$SRC_DIR/musl-wcc" wcc-musl

# Write out Makefile
MAKEFILE=Makefile
cat > $MAKEFILE <<END
include $SRC_DIR/Makefile
END

    # Copy musl-wcc wrapper over
    cp $SRC_DIR/musl-wcc $BUILD_DIR/
fi
