#!/bin/sh

set -e

# Configure:
# - as binary
# - ld binary
#
# The results are written to config.h

PREFIX=/usr # Default prefix

DEFAULT_AS_COMMAND="${AS:-$(command -v as  || true)}"   # Default assembler.
DEFAULT_LD_COMMAND="${LD:-$(command -v ld  || true)}"   # Default linker.

# Show the help
help() {
    cat <<END
Usage: ./configure [options]

Flags:
--prefix=PATH Install prefix, default: /usr
--as=PATH     Use assembler binary (detected: $DEFAULT_AS_COMMAND)
--ld=PATH     Use linker binary    (detected: $DEFAULT_LD_COMMAND)
-h, --help    Print this help text.
END
    exit 0
}

# Parse args
for arg in "$@"; do
    case $arg in
    --prefix=*)   PREFIX="${arg#*=}" ;;
    --as=*)       DEFAULT_AS_COMMAND="${arg#*=}" ;;
    --ld=*)       DEFAULT_LD_COMMAND="${arg#*=}" ;;
    -h|--help) help ;;
    *) echo "Unknown arg: $arg" >&2; exit 1 ;;
    esac
    shift || true
done

# gcc C runtime files
GCC_LIBRARY_PATH=/usr/lib/gcc/x86_64-linux-gnu/9
GCC_CRTBEGIN=/usr/lib/gcc/x86_64-linux-gnu/9/crtbeginS.o
GCC_CRTEND=/usr/lib/gcc/x86_64-linux-gnu/9/crtendS.o

# Libc configs are chosen at runtime via wcc --libc=glibc|musl.
GLIBC_DYNAMIC_LINKER=/lib64/ld-linux-x86-64.so.2
GLIBC_LIBC_LIBRARY_PATH=/usr/lib
GLIBC_STARTFILES="/usr/lib/x86_64-linux-gnu/crt1.o /usr/lib/x86_64-linux-gnu/crti.o $GCC_CRTBEGIN"
GLIBC_ENDFILES="$GCC_CRTEND /usr/lib/x86_64-linux-gnu/crtn.o"
GLIBC_INCLUDE_PATHS='"/usr/lib/gcc/x86_64-linux-gnu/9/include", "/usr/local/include", "/usr/include/x86_64-linux-gnu", "/usr/include"'

MUSL_DYNAMIC_LINKER=/lib/ld-musl-x86_64.so.1
MUSL_LIBC_LIBRARY_PATH=/usr/lib/x86_64-linux-musl
MUSL_STARTFILES="/usr/lib/x86_64-linux-musl/Scrt1.o /usr/lib/x86_64-linux-musl/crti.o $GCC_CRTBEGIN"
MUSL_ENDFILES="$GCC_CRTEND /usr/lib/x86_64-linux-musl/crtn.o"
MUSL_INCLUDE_PATHS='"/usr/include/x86_64-linux-musl", "/usr/lib/gcc/x86_64-linux-gnu/9/include"'

echo Using assembler $DEFAULT_AS_COMMAND
echo Using linker $DEFAULT_LD_COMMAND

# Write out config.h
CONFIG_H_PATH=config.h

cat > $CONFIG_H_PATH <<END
// This file is auto generated. Do not edit.

#define DEFAULT_AS_COMMAND "$DEFAULT_AS_COMMAND"
#define DEFAULT_LD_COMMAND "$DEFAULT_LD_COMMAND"
#define GCC_LIBRARY_PATH "$GCC_LIBRARY_PATH"
#define GLIBC_DYNAMIC_LINKER "$GLIBC_DYNAMIC_LINKER"
#define GLIBC_LIBC_LIBRARY_PATH "$GLIBC_LIBC_LIBRARY_PATH"
#define GLIBC_STARTFILES "$GLIBC_STARTFILES"
#define GLIBC_ENDFILES "$GLIBC_ENDFILES"
#define GLIBC_INCLUDE_PATHS $GLIBC_INCLUDE_PATHS
#define MUSL_DYNAMIC_LINKER "$MUSL_DYNAMIC_LINKER"
#define MUSL_LIBC_LIBRARY_PATH "$MUSL_LIBC_LIBRARY_PATH"
#define MUSL_STARTFILES "$MUSL_STARTFILES"
#define MUSL_ENDFILES "$MUSL_ENDFILES"
#define MUSL_INCLUDE_PATHS $MUSL_INCLUDE_PATHS
END

SRC_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
BUILD_DIR=$(pwd)

# Write out config.mk
CONFIG_MK_PATH=config.mk
cat > $CONFIG_MK_PATH <<END
PREFIX := $PREFIX
END

if [ "$SRC_DIR" != "$BUILD_DIR" ]
then
    mkdir -p tools
    mkdir -p tests/unit
    mkdir -p tests/integration
    mkdir -p tests/cpp
    mkdir -p tests/e2e

# Write out Makefile
MAKEFILE=Makefile
cat > $MAKEFILE <<END
PREFIX := $PREFIX
SRC_DIR := $SRC_DIR
BUILD_DIR := $BUILD_DIR
include \$(SRC_DIR)/Makefile
END
fi
